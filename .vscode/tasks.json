{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Portal (integrated)",
      "dependsOn": ["Start Backend API","Start Frontend Portal","Run Portal Smoke Test"],
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": []
    },
    {
      "label": "Start Backend API",
      "type": "shell",
      "command": "conda run -n EncuestasBackendAzure -- uvicorn app:app --reload --host 127.0.0.1 --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "problemMatcher": [],
      "runOptions": {},
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      }
    },
    {
      "label": "Start Frontend Portal",
      "type": "shell",
      "command": "conda run -n EncuestasFrontendAzure -- npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "problemMatcher": [],
      "runOptions": {},
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      }
    }
    ,
    {
      "label": "Run Portal Smoke Test",
      "type": "shell",
      "command": "pytest backend/tests/test_portal_job_flow.py -q",
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      }
    }
  ]
}
